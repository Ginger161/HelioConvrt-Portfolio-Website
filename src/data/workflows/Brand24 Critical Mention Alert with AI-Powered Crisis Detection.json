        240,
        304
      ],
      "webhookId": "e4d7dba9-33fa-4ce4-83e3-84fa90152c54"
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "mode": "list",
          "value": "claude-3-5-sonnet-20241022"
        },
        "messages": {
          "values": [
            {
              "content": "=Analyze this brand mention and determine if it represents a critical PR crisis requiring immediate intervention.\n\nMention text: {{ $json.body.text }}\nAuthor: {{ $json.body.author }}\nSentiment: {{ $json.body.sentiment }}\nReach: {{ $json.body.reach }}\n\nA critical PR crisis is defined as:\n- Viral negative content (high reach + negative sentiment)\n- Mentions of safety issues, legal problems, or serious harm\n- Influential accounts spreading negative information\n- Potential for widespread reputational damage\n\nRespond with ONLY \"CRITICAL\" or \"ROUTINE\" followed by a brief explanation."
            }
          ]
        },
        "options": {
          "maxTokens": 200
        }
      },
      "id": "2ffa3f54-439d-45d3-a153-bd2c94e4af8f",
      "name": "Analyze PR Crisis",
      "type": "@n8n/n8n-nodes-langchain.anthropic",
      "typeVersion": 1,
      "position": [
        464,
        304
      ]
    },
    {
      "parameters": {
        "conditions": {
          "combinator": "and",
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "leftValue": "={{ $json.response }}",
              "rightValue": "CRITICAL",
              "operator": {
                "type": "string",
                "operation": "contains"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "41d3d18b-b859-44b3-b6fd-d3a6f3bc9e22",
      "name": "Is Critical Crisis?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        816,
        304
      ]
    },
    {
      "parameters": {
        "authentication": "apiToken",
        "resource": "incident",
        "operation": "create",
        "title": "=CRITICAL PR CRISIS: Brand mention requires immediate attention",
        "serviceId": "={{ $json.serviceId }}",
        "email": "={{ $json.email }}",
        "additionalFields": {
          "details": "=Brand24 detected a critical mention:\n\nMention: {{ $(\"Brand24 Mention\").item.json.body.text }}\nAuthor: {{ $(\"Brand24 Mention\").item.json.body.author }}\nURL: {{ $(\"Brand24 Mention\").item.json.body.url }}\nReach: {{ $(\"Brand24 Mention\").item.json.body.reach }}\n\nAI Analysis: {{ $(\"Analyze PR Crisis\").item.json.response }}",
          "urgency": "high"
        },
        "conferenceBridgeUi": {}
      },
