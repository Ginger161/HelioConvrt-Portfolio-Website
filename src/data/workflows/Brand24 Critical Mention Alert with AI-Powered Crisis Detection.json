{
  "name": "Brand24 Critical Mention Alert with AI-Powered Crisis Detection",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "brand24-mention",
        "options": {}
      },
      "id": "2be92903-da59-4c38-b380-73a1b5892160",
      "name": "Brand24 Mention",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
