      "typeVersion": 1,
      "position": [
        336,
        320
      ],
      "disabled": true
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 1
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.fulfillment_status }}",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    },
                    "rightValue": "fulfilled"
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Fulfilled"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra",
          "renameFallbackOutput": "Not Fulfilled"
        }
      },
      "id": "1d96f792-6f2c-4ef1-adb6-752b50f25e8c",
      "name": "Check If Fulfilled",
