      "typeVersion": 3.4,
      "position": [
        560,
        320
      ]
    },
    {
      "parameters": {
        "operation": "update",
        "id": "={{ $(\"Zendesk Ticket Trigger\").item.json.ticket.id }}",
        "updateFields": {
          "publicReply": "=Hi {{ $(\"Zendesk Ticket Trigger\").item.json.ticket.requester.name }},\n\nGreat news! Your order has already been fulfilled and is on its way. You can track it here: {{ $json.order_status_url }}\n\nThanks!",
          "status": "solved"
        }
      },
      "id": "2f9e9e26-d340-4fe3-882a-94d99f6bcd33",
